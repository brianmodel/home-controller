# Secrets for the firmware (the `lights` binary). Copy this file to `wifi.env`
# and fill it in. `wifi.env` is gitignored so nothing here gets committed.
#
#     cp wifi.env.example wifi.env
#     # edit wifi.env, then:
#     make flash
#
# Everything is read via option_env!() at build time and baked into the flashed
# binary (not stored on a filesystem on the device).

# --- WiFi ---
export WIFI_SSID="your-network-name"
export WIFI_PASSWORD="your-network-password"

# --- Home Assistant (to control the lights) ---
# HA_HOST must be an IP address (no DNS lookup on-device). Port is usually 8123.
export HA_HOST="10.0.0.x"
export HA_PORT="8123"
# Long-lived access token: HA profile -> Long-Lived Access Tokens -> Create.
export HA_TOKEN="paste-long-lived-token-here"
# Comma-separated entity IDs of the switch(es)/light(s) to toggle.
export HA_ENTITIES="switch.living_room,switch.bedroom"

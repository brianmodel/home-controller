# WiFi credentials for the networked firmware (the `lights` binary).
#
# Copy this file to `wifi.env` and fill in your network. `wifi.env` is
# gitignored so your real credentials never get committed.
#
#     cp wifi.env.example wifi.env
#     # edit wifi.env, then:
#     make lights
#
# The Makefile sources wifi.env and the firmware reads these at build time via
# option_env!(), so they are baked into the flashed binary (not stored on a
# filesystem on the device).
export WIFI_SSID="your-network-name"
export WIFI_PASSWORD="your-network-password"
